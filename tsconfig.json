// prettier-ignore
{
  "extends": "@tsconfig/react-native/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@lib/*": [
        "./lib/*"
      ],
      "@features/*": [
        "./src/features/*"
      ],
      "@core/*": [
        "./src/core/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ]
    },
    "types": [
      "node",
      "@types/jest"
    ],
    "skipLibCheck": true,
    "strictNullChecks": true
  }
}