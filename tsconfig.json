{
  "extends": "@react-native/typescript-config",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["./lib/*"],
      "~/*": ["./src/*"]
    },
    "types": ["node"],
    "skipLibCheck": true,
    "strictNullChecks": true
  }
}
